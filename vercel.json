{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "builds": [
    { 
      "src": "server/server.js", 
      "use": "@vercel/node",
      "config": { "includeFiles": ["public/**"] }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/server.js" },
    { "src": "/(.*)", "dest": "public/$1", "check": true },
    { "src": "/(.*)", "status": 200, "dest": "public/index.html" }
  ]
}